# ─── Supabase (backend, server-only) ──────────────────────────────────────
# Project: platizhka-fin (eu-central-1, project_id yetuzdftyyklmeiglbiq)
SUPABASE_URL=https://yetuzdftyyklmeiglbiq.supabase.co

# Publishable key (anon-equivalent, safe for read-only public ops)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InlldHV6ZGZ0eXlrbG1laWdsYmlxIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzcwNjYzNTAsImV4cCI6MjA5MjY0MjM1MH0.g-mRRdDFpudsTCLimTN_JcOmN3fR-tdaLnCNn-YerS4

# Service role key — REQUIRED for server-side. Get from:
#   Supabase Dashboard → Project Settings → API → service_role key
# This key bypasses RLS — never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Direct Postgres connection (for psql, migrations, jobs that need raw SQL).
# Get from: Supabase Dashboard → Project Settings → Database → Connection string
POSTGRES_URL=postgres://postgres.[ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# ─── Auth ─────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_long_random_string

# ─── App ──────────────────────────────────────────────────────────────────
PORT=3001
FRONTEND_URL=http://localhost:3000
# Public URL of the storefront widget. Defaults to FRONTEND_URL + /widget.js.
# For Shopify stores this must be a public HTTPS URL, not localhost.
SHOPIFY_WIDGET_URL=

# ─── Notifications ────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_NOTIFY_CHAT_ID=
TURBOSMS_TOKEN=
SHORT_LINK_API=
SHORT_LINK_TOKEN=

# ─── Payments ─────────────────────────────────────────────────────────────
# Public base URL of THIS API — used to build webhook URLs for payment
# providers (e.g. Monobank webHookUrl). Must be HTTPS reachable from internet.
API_PUBLIC_URL=https://platizhka-back.vercel.app

# ─── Payments / per-provider sandbox tokens ───────────────────────────────
# When a shop toggles is_test=true on a payment method we use these platform
# fallback tokens, so a merchant can test integration without registering
# their own sandbox merchant.

# Monobank Acquiring sandbox token (same X-Token format as live).
# Monobank does NOT publish a shared sandbox token — register a test
# merchant in your own Monobank account at https://web.monobank.ua/
# and paste the X-Token here. Leave empty to require merchants to paste
# their own test_token in shop credentials when enabling test mode.
MONO_TEST_TOKEN=

# WayForPay test merchant — public sandbox credentials documented by
# WayForPay (works for any project).
WAYFORPAY_TEST_MERCHANT=test_merch_n1
WAYFORPAY_TEST_SECRET=flk3409refn54t54t*FNJRET

# LiqPay test mode — pass `sandbox: 1` on requests; uses the merchant's
# real public_key/private_key. No platform-wide test keys.

# Fondy test sandbox merchant — public docs.
FONDY_TEST_MERCHANT_ID=1396424
FONDY_TEST_SECRET=test

# ─── Shopify OAuth ────────────────────────────────────────────────────────
# Merchant apps provide Client ID/Secret in shop settings.
# Platform only defines scopes requested during install.
SHOPIFY_SCOPES=read_customers,write_customers,read_discounts,write_discounts,write_draft_orders,read_draft_orders,read_fulfillments,write_fulfillments,read_gift_cards,write_gift_cards,write_inventory,read_inventory,read_markets,write_markets,write_order_edits,read_order_edits,read_orders,write_orders,read_products,write_products,read_themes,write_themes,unauthenticated_write_bulk_operations,unauthenticated_read_bulk_operations,unauthenticated_read_bundles,unauthenticated_write_checkouts,unauthenticated_read_checkouts,unauthenticated_write_customers,unauthenticated_read_customers,unauthenticated_read_customer_tags,unauthenticated_read_metaobjects,unauthenticated_read_product_pickup_locations,unauthenticated_read_product_inventory,unauthenticated_read_product_listings,unauthenticated_read_product_tags,unauthenticated_read_selling_plans,unauthenticated_read_shop_pay_installments_pricing,unauthenticated_read_content
